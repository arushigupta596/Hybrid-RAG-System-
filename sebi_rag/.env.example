# OpenRouter (unified LLM gateway — openrouter.ai)
OPENROUTER_API_KEY=your_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=anthropic/claude-sonnet-4-6
APP_SITE_URL=http://localhost:5173
APP_TITLE=SEBI RBI Regulatory Intelligence

# Cohere (optional — re-ranking falls back to local cross-encoder if absent)
COHERE_API_KEY=your_key_here

# Elasticsearch
ES_HOST=http://localhost:9200
ES_INDEX_NAME=sebi_rbi_chunks

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=sebi_rbi_vectors

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sebi_rag
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Embedding model
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIM=1024
EMBEDDING_BATCH_SIZE=32

# Retrieval defaults
BM25_TOP_K=20
VECTOR_TOP_K=20
RRF_K=60
RERANK_TOP_K=5
LLM_CONTEXT_CHUNKS=5

# Paths
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
CUTOFF_DATE=2015-01-01
